---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { actions, isInputError } from "astro:actions";
import { readServices } from "../../lib/services-store";

const adminUser = await Astro.session?.get("adminUser");
if (!adminUser) {
  return Astro.redirect("/admin/login");
}

const services = await readServices();

const saveResult = Astro.getActionResult(actions.saveService);
const removeResult = Astro.getActionResult(actions.removeService);

const inputErrors = isInputError(saveResult?.error) ? saveResult.error.fields : {};
const saveSuccess = saveResult && !saveResult.error ? saveResult.data : null;
const removeSuccess = removeResult && !removeResult.error ? removeResult.data : null;
---

<BaseLayout title="管理员后台 - Services" description="管理服务信息">
  <main class="container page">
    <div class="section-head">
      <div>
        <div class="section-kicker">Admin</div>
        <h1 class="section-title">服务后台编辑</h1>
        <p class="section-desc">修改后首页与服务详情页会立即读取最新服务数据。</p>
      </div>

      <a class="btn btn-ghost" href="/admin">返回后台</a>
    </div>

    {saveSuccess && (
      <div class="contact-notice contact-notice--success mt-4">
        {saveSuccess.message}
      </div>
    )}

    {removeSuccess && (
      <div class="contact-notice contact-notice--success mt-4">
        {removeSuccess.message}
      </div>
    )}

    <div class="contact-shell mt-4">
      <div class="h3">新增服务</div>

      <form method="POST" action={actions.saveService} class="mt-4 service-form">
        <div class="form-grid">
          <div class="form-item">
            <label class="form-label">服务标题</label>
            <input class="input" name="title" type="text" required />
            {inputErrors.title && <p class="form-error">{inputErrors.title.join("，")}</p>}
          </div>

          <div class="form-item">
            <label class="form-label">副标题</label>
            <input class="input" name="subtitle" type="text" />
          </div>
        </div>

        <div class="form-grid mt-4">
          <div class="form-item">
            <label class="form-label">分类</label>
            <select class="input" name="category">
              <option value="language">语言</option>
              <option value="abroad">留学</option>
            </select>
          </div>

          <div class="form-item">
            <label class="form-label">排序</label>
            <input class="input" name="order" type="number" value="999" required />
            {inputErrors.order && <p class="form-error">{inputErrors.order.join("，")}</p>}
          </div>
        </div>

        <div class="form-grid mt-4">
          <div class="form-item">
            <label class="form-label">图标</label>
            <input class="input" name="icon" type="text" placeholder="🎯" />
          </div>

          <div class="form-item">
            <label class="form-label">Hero 图片路径</label>
            <input
              class="input"
              name="heroImage"
              type="text"
              placeholder="/uploads/services/xxx.jpg"
              data-service-image-path
            />
          </div>
        </div>

        <div class="form-item mt-4">
          <label class="form-label">上传服务图片</label>
          <input class="input" type="file" accept="image/*" data-service-image-upload />
          <p class="muted mt-2" data-service-upload-status></p>
          <img
            class="mt-3"
            data-service-image-preview
            style="max-width: 220px; border-radius: 16px; display:none;"
          />
        </div>

        <div class="form-item mt-4">
          <label class="form-label">官网入口</label>
          <input class="input" name="officialRegisterUrl" type="text" placeholder="https://..." />
        </div>

        <div class="form-item mt-4">
          <label class="form-label">服务介绍</label>
          <textarea class="input" name="summary" placeholder="每行都可以写一点介绍"></textarea>
        </div>

        <div class="form-grid mt-4">
          <div class="form-item">
            <label class="form-label">亮点（每行一条）</label>
            <textarea class="input" name="highlights" placeholder="入学诊断&#10;阶段测评&#10;模考复盘"></textarea>
          </div>

          <div class="form-item">
            <label class="form-label">FAQ（每行一条，格式：问题 | 回答）</label>
            <textarea class="input" name="faqs" placeholder="需要基础吗？ | 可以先做诊断&#10;可以单科报名吗？ | 可以"></textarea>
          </div>
        </div>

        <div class="form-item mt-4">
          <label class="form-label">标签（逗号分隔）</label>
          <input class="input" name="tags" type="text" placeholder="TOEFL, 口语, 写作" />
        </div>

        <div class="mt-4">
          <button class="btn" type="submit">新增服务</button>
        </div>
      </form>
    </div>

    <div class="cards mt-6">
      {services.map((service) => (
        <div class="card">
          <div class="card-top">
            <div>
              <div class="h3">{service.title}</div>
              <div class="muted mt-1">{service.subtitle}</div>
            </div>
            <div class="badge">#{service.order}</div>
          </div>

          <form method="POST" action={actions.saveService} class="mt-4 service-form">
            <input type="hidden" name="id" value={service.id} />

            <div class="form-grid">
              <div class="form-item">
                <label class="form-label">服务标题</label>
                <input class="input" name="title" type="text" value={service.title} required />
              </div>

              <div class="form-item">
                <label class="form-label">副标题</label>
                <input class="input" name="subtitle" type="text" value={service.subtitle} />
              </div>
            </div>

            <div class="form-grid mt-4">
              <div class="form-item">
                <label class="form-label">分类</label>
                <select class="input" name="category">
                  <option value="language" selected={service.category === "language"}>语言</option>
                  <option value="abroad" selected={service.category === "abroad"}>留学</option>
                </select>
              </div>

              <div class="form-item">
                <label class="form-label">排序</label>
                <input class="input" name="order" type="number" value={service.order} required />
              </div>
            </div>

            <div class="form-grid mt-4">
              <div class="form-item">
                <label class="form-label">图标</label>
                <input class="input" name="icon" type="text" value={service.icon ?? ""} />
              </div>

              <div class="form-item">
                <label class="form-label">Hero 图片路径</label>
                <input
                  class="input"
                  name="heroImage"
                  type="text"
                  value={service.heroImage ?? ""}
                  data-service-image-path
                />
              </div>
            </div>

            <div class="form-item mt-4">
              <label class="form-label">上传/替换服务图片</label>
              <input class="input" type="file" accept="image/*" data-service-image-upload />
              <p class="muted mt-2" data-service-upload-status></p>
              {service.heroImage ? (
                <img
                  class="mt-3"
                  src={service.heroImage}
                  data-service-image-preview
                  style="max-width: 220px; border-radius: 16px;"
                />
              ) : (
                <img
                  class="mt-3"
                  data-service-image-preview
                  style="max-width: 220px; border-radius: 16px; display:none;"
                />
              )}
            </div>

            <div class="form-item mt-4">
              <label class="form-label">官网入口</label>
              <input
                class="input"
                name="officialRegisterUrl"
                type="text"
                value={service.officialRegisterUrl ?? ""}
              />
            </div>

            <div class="form-item mt-4">
              <label class="form-label">服务介绍</label>
              <textarea class="input" name="summary">{service.summary ?? ""}</textarea>
            </div>

            <div class="form-grid mt-4">
              <div class="form-item">
                <label class="form-label">亮点（每行一条）</label>
                <textarea class="input" name="highlights">{service.highlights.join("\n")}</textarea>
              </div>

              <div class="form-item">
                <label class="form-label">FAQ（每行一条，格式：问题 | 回答）</label>
                <textarea class="input" name="faqs">{service.faqs.map((item) => `${item.q} | ${item.a}`).join("\n")}</textarea>
              </div>
            </div>

            <div class="form-item mt-4">
              <label class="form-label">标签（逗号分隔）</label>
              <input class="input" name="tags" type="text" value={service.tags.join(", ")} />
            </div>

            <div class="mt-4" style="display:flex; gap:10px; flex-wrap:wrap;">
              <button class="btn" type="submit">保存修改</button>
            </div>
          </form>

          <form method="POST" action={actions.removeService} class="mt-3">
            <input type="hidden" name="id" value={service.id} />
            <button class="btn btn-ghost" type="submit">删除服务</button>
          </form>
        </div>
      ))}
    </div>
  </main>

  <script is:inline>
    (() => {
      const forms = document.querySelectorAll(".service-form");

      forms.forEach((form) => {
        const uploadInput = form.querySelector("[data-service-image-upload]");
        const pathInput = form.querySelector("[data-service-image-path]");
        const statusEl = form.querySelector("[data-service-upload-status]");
        const previewEl = form.querySelector("[data-service-image-preview]");

        if (!(uploadInput instanceof HTMLInputElement)) return;
        if (!(pathInput instanceof HTMLInputElement)) return;

        uploadInput.addEventListener("change", async () => {
          const file = uploadInput.files?.[0];
          if (!file) return;

          if (statusEl) statusEl.textContent = "上传中...";

          const formData = new FormData();
          formData.append("file", file);

          try {
            const res = await fetch("/api/admin/upload-service-image", {
              method: "POST",
              body: formData,
            });

            const rawText = await res.text();
            let data = null;

            try {
              data = JSON.parse(rawText);
            } catch {
              throw new Error(`上传接口返回了非 JSON 内容：${rawText.slice(0, 120)}`);
            }

            if (!res.ok || !data?.ok) {
              throw new Error(data?.message || "上传失败");
            }

            pathInput.value = data.path;

            if (previewEl instanceof HTMLImageElement) {
              previewEl.src = data.path;
              previewEl.style.display = "block";
            }

            if (statusEl) statusEl.textContent = "上传成功";
          } catch (error) {
            if (statusEl) {
              statusEl.textContent =
                error instanceof Error ? error.message : "上传失败";
            }
          }
        });
      });
    })();
  </script>
</BaseLayout>