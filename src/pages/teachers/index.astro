---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { normalizeImageUrl } from "../../lib/image-url";
import { readSiteSettings } from "../../lib/site-store";
import { readTeachers } from "../../lib/teachers-store";

const site = await readSiteSettings();
const teachers = await readTeachers();
---

<BaseLayout title={`师资团队 · ${site.companyName}`} description="老师介绍与擅长方向">
  <main class="container page">
    <a class="breadcrumb" href="/">← 返回首页</a>

    <header class="page-hero">
      <div class="section-kicker">Teachers</div>
      <h1 class="section-title">师资团队</h1>
      <p class="section-desc">点击老师卡片进入详情页</p>
    </header>

    {teachers.length ? (
      <section class="mt-8 cards cards--2">
        {teachers.map((teacher) => (
          <a class="card teacher-card card--hover" href={`/teachers/${teacher.id}`}>
            <div class="teacher-top">
              {teacher.avatar ? (
                <img
                  class="avatar"
                  src={normalizeImageUrl(teacher.avatar)}
                  alt={teacher.name}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="avatar avatar--ph">{teacher.name.slice(0, 1)}</div>
              )}

              <div>
                <div class="h3">{teacher.name}</div>
                <div class="muted">{teacher.title}</div>
              </div>
            </div>

            {teacher.intro ? <p class="muted mt-3">{teacher.intro}</p> : null}

            {teacher.specialties.length ? (
              <div class="tags mt-3">
                {teacher.specialties.slice(0, 6).map((specialty) => (
                  <span class="tag">{specialty}</span>
                ))}
              </div>
            ) : null}

            <div class="card-cta mt-4">查看详情 →</div>
          </a>
        ))}
      </section>
    ) : (
      <div class="card mt-4">
        <div class="h3">暂无老师数据</div>
      </div>
    )}
  </main>
</BaseLayout>
