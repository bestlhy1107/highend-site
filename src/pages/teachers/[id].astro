---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { normalizeImageUrl } from "../../lib/image-url";
import { readSiteSettings } from "../../lib/site-store";
import { readTeacherById } from "../../lib/teachers-store";

const site = await readSiteSettings();

const id = Astro.params.id;
if (!id) {
  return Astro.redirect("/teachers");
}

const teacher = await readTeacherById(id);
if (!teacher) {
  return Astro.redirect("/teachers");
}
---

<BaseLayout
  title={`${teacher.name} · ${site.companyName}`}
  description={teacher.title}
>
  <main class="container page">
    <a class="breadcrumb" href="/teachers">← 返回师资列表</a>

    <header class="detail-hero mt-4">
      <div class="teacher-top">
        {teacher.avatar ? (
          <img
            src={normalizeImageUrl(teacher.avatar)}
            alt={teacher.name}
            class="avatar"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="avatar avatar--ph">{teacher.name.slice(0, 1)}</div>
        )}
        <div>
          <div class="section-kicker">Teacher Detail</div>
          <h1 class="section-title">{teacher.name}</h1>
          <p class="section-desc">{teacher.title}</p>
        </div>
      </div>

      <aside class="card">
        <div class="h3">擅长方向</div>
        {teacher.specialties.length ? (
          <div class="tags">
            {teacher.specialties.map((specialty) => (
              <span class="tag">{specialty}</span>
            ))}
          </div>
        ) : (
          <p class="muted mt-2">暂无擅长方向。</p>
        )}
      </aside>
    </header>

    <div class="detail-grid">
      <article class="prose">
        <h2>老师简介</h2>
        <p>{teacher.intro || "暂无老师简介。"}</p>
      </article>

      <aside class="card">
        <div class="h3">标签</div>
        {teacher.badges.length ? (
          <div class="tags">
            {teacher.badges.map((badge) => (
              <span class="badge">{badge}</span>
            ))}
          </div>
        ) : (
          <p class="muted mt-2">暂无标签。</p>
        )}
      </aside>
    </div>
  </main>
</BaseLayout>
