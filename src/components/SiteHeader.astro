---
type Props = {
  brand?: string;
  currentPath?: string;
};

const { brand = "Highend Site", currentPath = "/" } = Astro.props as Props;

const nav = [
  { label: "首页", href: "/" , match: (p: string) => p === "/" },
  { label: "服务", href: "/services", match: (p: string) => p.startsWith("/services") },
  { label: "考试", href: "/exams", match: (p: string) => p.startsWith("/exams") },
  { label: "师资", href: "/teachers", match: (p: string) => p.startsWith("/teachers") },
  { label: "动态", href: "/#news", match: (p: string) => p === "/" },
  { label: "联系", href: "/#contact", match: (_p: string) => false },
];
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Go to home">
      <span class="brand-mark">◆</span>
      <span class="brand-text">{brand}</span>
    </a>

    <button class="nav-toggle" type="button" aria-label="Toggle menu" data-toggle>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav class="nav" aria-label="Primary" data-nav>
      <div class="nav-links">
        {nav.map((item) => {
          const active = item.match(currentPath);
          return (
            <a class={`nav-link ${active ? "is-active" : ""}`} href={item.href}>
              {item.label}
            </a>
          );
        })}
      </div>

      <div class="nav-cta">
        <a class="btn btn-ghost" href="/#news">最新动态</a>
        <a class="btn" href="/#contact">立即咨询</a>
      </div>
    </nav>
  </div>

  <script is:inline>
    (() => {
      const header = document.currentScript?.closest("[data-header]");
      if (!header) return;
      const toggle = header.querySelector("[data-toggle]");
      const nav = header.querySelector("[data-nav]");
      if (!(toggle instanceof HTMLElement) || !(nav instanceof HTMLElement)) return;

      toggle.addEventListener("click", () => {
        const open = header.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      });

      // 点击导航项后自动收起（移动端）
      nav.addEventListener("click", (e) => {
        const a = (e.target && e.target.closest && e.target.closest("a")) || null;
        if (a) header.classList.remove("is-open");
      });
    })();
  </script>
</header>
